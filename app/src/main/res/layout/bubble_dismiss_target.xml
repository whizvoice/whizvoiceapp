<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dismiss_target"
    android:layout_width="180dp"
    android:layout_height="180dp"
    android:background="@drawable/dismiss_target_circle"
    android:contentDescription="Dismiss bubble target">

    <ImageView
        android:id="@+id/dismiss_icon"
        android:layout_width="78dp"
        android:layout_height="78dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_close_thin"
        android:contentDescription="Dismiss icon" />

</FrameLayout>
