# Copy this file to local.properties and fill in your values.
# local.properties is gitignored and will not be committed.

# Android SDK location (auto-set by Android Studio)
# sdk.dir=/path/to/your/android/sdk

# Google OAuth client IDs (from Google Cloud Console → Credentials → OAuth 2.0 Client IDs)
GOOGLE_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
